# ===== GOOGLE DRIVE =====
# Your Google Drive folder ID (the folder you copied the sample to)
# Get this from the URL: https://drive.google.com/drive/folders/YOUR_FOLDER_ID
DRIVE_FOLDER_ID=your_folder_id_here

# Service Account JSON (copy the entire content as a JSON string)
# This is the JSON content from your Google Cloud service account key file
# Make sure to escape quotes properly or use single quotes
GOOGLE_SERVICE_ACCOUNT_JSON='{"type": "service_account", "project_id": "...", ...}'

# ===== LLM API KEYS =====
# Choose one or more LLM providers

# Groq (FREE - Recommended for testing)
# Sign up at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# OpenAI (Paid - But high quality)
# Get key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Google Gemini (Free tier available)
# Get key from: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# ===== API & FRONTEND =====
# Backend API URL (used by Streamlit)
API_URL=http://localhost:8000

# Streamlit API secret (optional, for production)
STREAMLIT_SERVER_HEADLESS=true
STREAMLIT_SERVER_PORT=8501
